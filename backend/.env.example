# ═══════════════════════════════════════════════════════════════════════════════
# FlowTask Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# In production (Render), set these in the service's Environment tab.
#
# ⚠️  NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ─── URLs ─────────────────────────────────────────────────────────────────────
# These are REQUIRED in production. Used for CORS, email links, redirects.
FRONTEND_URL=https://flowtask-x3z4.onrender.com
CHATAPP_URL=https://flowtask-client.onrender.com

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<generate-64-char-hex-secret>
JWT_EXPIRE=7d

# ─── Chat Integration ────────────────────────────────────────────────────────
# All four variables are REQUIRED when CHAT_ENABLED=true in production.
CHAT_ENABLED=true

# Secret used to SIGN JWT tokens for ChatApp SSO login.
# ⚠️  MUST exactly match ChatApp's FLOWTASK_JWT_SECRET
CHAT_JWT_SECRET=<must-match-ChatApp-FLOWTASK_JWT_SECRET>

# Webhook endpoint on ChatApp backend that receives events.
CHAT_WEBHOOK_URL=https://flowtask-chat-app.onrender.com/api/chat/webhooks/flowtask

# Secret used to SIGN webhook payloads (HMAC-SHA256).
# ⚠️  MUST exactly match ChatApp's FLOWTASK_WEBHOOK_SECRET
FLOWTASK_WEBHOOK_SECRET=<must-match-ChatApp-FLOWTASK_WEBHOOK_SECRET>

# Legacy alias — some code reads CHAT_WEBHOOK_SECRET. Keep same value as above.
CHAT_WEBHOOK_SECRET=<same-value-as-FLOWTASK_WEBHOOK_SECRET>

# ─── Redis (optional — enables BullMQ, Socket.IO adapter) ────────────────────
# REDIS_URL=redis://<user>:<password>@<host>:<port>

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Slack Integration ───────────────────────────────────────────────────────
# SLACK_ENABLED=true
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
